---
const testimonials = [
  {
    quote: "Walking into LuxStay felt like stepping into a dream — one I never wanted to wake from. The level of personalised service is something I've never experienced anywhere in the world.",
    name: 'Isabella Hartmann',
    role: 'Creative Director, Berlin',
    avatar: 'https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=100&h=100&q=80&auto=format&fit=crop&crop=face',
    stars: 5,
  },
  {
    quote: "Our honeymoon at LuxStay was nothing short of magical. The overwater villa, the private beach dinners, and the staff who remembered every small preference — simply extraordinary.",
    name: 'James & Sofia Chen',
    role: 'Newlyweds, Singapore',
    avatar: 'https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=100&h=100&q=80&auto=format&fit=crop&crop=face',
    stars: 5,
  },
  {
    quote: "I've stayed at luxury hotels across six continents. LuxStay is the only one I've returned to four times. It's not just the facilities — it's the feeling of being truly cared for.",
    name: 'Ambassador Raúl Vega',
    role: 'Diplomat, Madrid',
    avatar: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&h=100&q=80&auto=format&fit=crop&crop=face',
    stars: 5,
  },
];
---

<section class="testimonials-section">
  <div class="container">
    <div class="test-header">
      <p class="section-label">Guest Stories</p>
      <h2 class="section-title">Moments That <em>Last a Lifetime</em></h2>
    </div>

    <div class="test-grid">
      {testimonials.map(({ quote, name, role, avatar, stars }) => (
        <div class="test-card">
          <div class="stars">
            {'★'.repeat(stars)}
          </div>
          <blockquote class="test-quote">
            "{quote}"
          </blockquote>
          <div class="test-author">
            <img src={avatar} alt={name} loading="lazy" />
            <div>
              <p class="test-name">{name}</p>
              <p class="test-role">{role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Press logos — pure static -->
    <div class="press-row">
      <p class="press-label">As Featured In</p>
      <div class="press-logos">
        {['Condé Nast', 'Forbes Travel', 'Vogue', 'The Times', 'Architectural Digest'].map((name) => (
          <span class="press-name">{name}</span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    padding: 8rem 0;
    background: var(--surface);
  }

  .test-header { margin-bottom: 3.5rem; }

  .test-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .test-card {
    padding: 2.5rem;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.015);
    transition: background 0.3s;
  }
  .test-card:hover { background: rgba(201, 168, 76, 0.03); }

  .stars {
    color: var(--gold);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    margin-bottom: 1.25rem;
  }

  .test-quote {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-style: italic;
    font-weight: 300;
    color: rgba(245, 240, 232, 0.85);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .test-author {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(201, 168, 76, 0.1);
  }

  .test-author img {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    filter: grayscale(0.3);
  }

  .test-name {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--white);
    font-weight: 500;
    margin-bottom: 0.15rem;
  }

  .test-role {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    color: var(--muted);
    letter-spacing: 0.05em;
  }

  /* Press */
  .press-row {
    margin-top: 5rem;
    text-align: center;
  }
  .press-label {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1.5rem;
  }
  .press-logos {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 3rem;
    flex-wrap: wrap;
  }
  .press-name {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 300;
    color: rgba(245, 240, 232, 0.25);
    letter-spacing: 0.08em;
    transition: color 0.3s;
    cursor: default;
  }
  .press-name:hover { color: rgba(245, 240, 232, 0.6); }

  @media (max-width: 900px) {
    .test-grid { grid-template-columns: 1fr; }
    .testimonials-section { padding: 5rem 0; }
    .press-logos { gap: 1.5rem; }
    .press-name { font-size: 0.9rem; }
  }
</style>
