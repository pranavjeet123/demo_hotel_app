---
import NewsletterForm from './islands/NewsletterForm.tsx';
---

<footer id="contact" class="footer">
  <div class="container">
    <!-- Top grid -->
    <div class="footer-top">
      <div class="footer-brand">
        <a href="#" class="footer-logo">LUXSTAY</a>
        <p class="footer-tagline">Est. 1998 · Resort & Spa</p>
        <p class="footer-about">
          Where the world's most discerning travellers come to rediscover what it means to
          truly rest, explore, and be inspired.
        </p>
        <div class="social-links">
          {['Instagram', 'Facebook', 'Twitter', 'LinkedIn'].map((s) => (
            <a href="#" class="social-link">{s}</a>
          ))}
        </div>
      </div>

      <div class="footer-links">
        <h4 class="footer-col-title">Resort</h4>
        <ul>
          {['Rooms & Suites', 'Dining', 'Spa & Wellness', 'Experiences', 'Weddings', 'Meetings & Events'].map((l) => (
            <li><a href="#">{l}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-links">
        <h4 class="footer-col-title">Information</h4>
        <ul>
          {['About Us', 'Gallery', 'Press & Media', 'Sustainability', 'Careers', 'Contact'].map((l) => (
            <li><a href="#">{l}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-newsletter">
        <h4 class="footer-col-title">Exclusive Offers</h4>
        <p class="newsletter-desc">
          Join our inner circle for early access to seasonal offers, member rates, and
          curated invitations to private events.
        </p>
        <!-- ★ ISLAND: client:idle — non-critical, loads when browser is free -->
        <NewsletterForm client:idle />
        <p class="newsletter-note">No spam. Unsubscribe anytime.</p>
      </div>
    </div>

    <!-- Divider -->
    <div class="footer-divider" />

    <!-- Bottom -->
    <div class="footer-bottom">
      <p class="footer-copy">
        © {new Date().getFullYear()} Island Architecture Resort & Spa. All rights reserved.
      </p>
      <div class="footer-legal">
        {['Privacy Policy', 'Terms of Service', 'Cookie Policy', 'Accessibility'].map((l) => (
          <a href="#">{l}</a>
        ))}
      </div>
    </div>

    <!-- Credit bar -->
    <div class="footer-credit">
      <p class="credit-text">
        Developed by&nbsp;
        <a
          href="https://www.linkedin.com/in/pranavjeet/"
          target="_blank"
          rel="noopener noreferrer"
          class="credit-link"
        >
          Pranavjeet Mishra
        </a>
        &nbsp;·&nbsp; Built with
        <span class="credit-tech">Astro</span>
        <span class="credit-sep">&</span>
        <span class="credit-tech">React Islands</span>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #050505;
    border-top: 1px solid rgba(201, 168, 76, 0.12);
    padding-top: 5rem;
    padding-bottom: 2rem;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 2fr;
    gap: 3rem;
    padding-bottom: 3.5rem;
  }

  .footer-logo {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    font-weight: 300;
    letter-spacing: 0.12em;
    color: var(--white);
    display: block;
    margin-bottom: 0.25rem;
  }

  .footer-tagline {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .footer-about {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 1.5rem;
    max-width: 280px;
  }

  .social-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .social-link {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--muted);
    text-transform: uppercase;
    transition: color 0.3s;
  }
  .social-link:hover { color: var(--gold); }

  .footer-col-title {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.25rem;
    font-weight: 500;
  }

  .footer-links ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-links a {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--muted);
    transition: color 0.3s;
    letter-spacing: 0.03em;
  }
  .footer-links a:hover { color: var(--cream); }

  .newsletter-desc {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .newsletter-note {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    color: rgba(119, 119, 119, 0.6);
    margin-top: 0.75rem;
    letter-spacing: 0.05em;
  }

  .footer-divider {
    height: 1px;
    background: rgba(201, 168, 76, 0.08);
    margin-bottom: 2rem;
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-copy {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    color: rgba(119, 119, 119, 0.6);
  }

  .footer-legal {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-legal a {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    color: rgba(119, 119, 119, 0.6);
    letter-spacing: 0.05em;
    transition: color 0.3s;
  }
  .footer-legal a:hover { color: var(--muted); }

  .footer-credit {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(201, 168, 76, 0.06);
    text-align: center;
  }

  .credit-text {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    color: rgba(119, 119, 119, 0.5);
    letter-spacing: 0.04em;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .credit-link {
    color: var(--gold);
    font-weight: 500;
    text-decoration: none;
    transition: color 0.3s, opacity 0.3s;
    border-bottom: 1px solid rgba(201, 168, 76, 0.35);
    padding-bottom: 1px;
  }
  .credit-link:hover {
    color: var(--gold-light);
    border-bottom-color: var(--gold-light);
  }

  .credit-tech {
    color: rgba(245, 240, 232, 0.45);
    font-weight: 500;
    letter-spacing: 0.06em;
  }

  .credit-sep { color: rgba(119, 119, 119, 0.35); margin: 0 0.1rem; }

  @media (max-width: 1024px) {
    .footer-top { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .footer-brand { grid-column: span 2; }
  }

  @media (max-width: 600px) {
    .footer-top { grid-template-columns: 1fr; }
    .footer-brand { grid-column: span 1; }
    .footer-bottom { flex-direction: column; text-align: center; }
    .footer-legal { justify-content: center; }
  }
</style>
